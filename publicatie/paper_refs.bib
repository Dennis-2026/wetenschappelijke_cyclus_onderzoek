  @article{DorisAbitzsch2024,
   abstract = {Universitaire   talenstudies   zoals   Duits   kampen   al   jaren  met  dalende  studentenaantallen.  Dit  leidt  tot  zorgelijk oplopende tekorten vooral aan taaldocenten voor  het  voortgezet  onderwijs.  Deze  trends  roepen  vragen op over de situatie van het Duits als schoolvak en  als  studie,  en  over  de  motivatie  en  interesse  van  studenten  Duits  aan  Nederlandse  universiteiten.  In  dit artikel onderzoeken we deze vragen.},
