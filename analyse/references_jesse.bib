@article{Krabbe2017,
   abstract = {"The first encyclopedia to cover inclusively both quantitative and qualitative research approaches, this set provides clear explanations of 1,000 methodologies, avoiding mathematical equations when possible with liberal cross-referencing and bibliographies. Each volume includes a list of works cited, and the third contains a comprehensive index and lists of person names, organizations, books, tests, software, major concepts, surveys, and methodologies."--"Reference that rocks," American Libraries, May 2005.},
   author = {Paul F.M. Krabbe},
   doi = {10.1016/B978-0-12-801504-9.00010-6},
   journal = {The Measurement of Health and Health Status},
   pages = {171-195},
   publisher = {Elsevier},
   title = {Item Response Theory},
   year = {2017}
}
